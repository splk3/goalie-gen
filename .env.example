# Example environment variables
# Copy this to .env.development or .env.production and set your values

# Site URL - used for SEO and sitemap generation
GATSBY_SITE_URL=https://your-domain.com

# Optional static-asset and client cache controls
GATSBY_ASSET_CACHE_BUST=1
GATSBY_DRILL_IMAGE_CACHE_TTL_MS=300000
GATSBY_DRILL_PDF_CACHE_TTL_MS=120000
GATSBY_OBJECT_URL_REVOKE_DELAY_MS=60000
